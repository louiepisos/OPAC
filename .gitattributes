* text=auto

*.blade.php diff=html
*.css diff=css
*.html diff=html
*.md diff=markdown
*.php diff=php

# Keep container/runtime files with Linux line endings even on Windows checkouts.
Dockerfile text eol=lf
docker-compose.yml text eol=lf
.dockerignore text eol=lf
docker/*.sh text eol=lf
*.sh text eol=lf

/.github export-ignore
CHANGELOG.md export-ignore
